<script defer src="/js/TextEditor.js"></script>

<div class="text-main">
    <div class="main-header">
        <input @ref="_titleInput" @onchange="HandleTitleInput" type="text" name="title" id="main-title"
               placeholder="Title">
        </div>

        <textarea @ref="_editorDiv" @onchange="HandleContentInput" name="textEditor"
                  id="main-text-content"></textarea>
    </div>

@code {
    [Parameter]
    public string Content { get; set; } = String.Empty;
    [Parameter]
    public string Title { get; set; } = String.Empty;

    [Parameter]
    public EventCallback<string> ContentChanged { get; set; }
    [Parameter]
    public EventCallback<string> TitleChanged { get; set; }

    private ElementReference _editorDiv;
    private ElementReference _titleInput;

    [Inject] private IJSRuntime JS { get; set; } = default!;

    private string? _lastRenderedContent;
    private string? _lastRenderedTitle;
    private bool _shouldSyncFromParameters;

    protected override Task OnParametersSetAsync()
    {
        if (Content != _lastRenderedContent || Title != _lastRenderedTitle)
        {
            _shouldSyncFromParameters = true;
        }

        return Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_shouldSyncFromParameters)
        {
            _shouldSyncFromParameters = false;
            _lastRenderedContent = Content;
            _lastRenderedTitle = Title;

            await InsertEntryAsync(Content, Title);
        }
    }

    private async Task HandleContentInput(ChangeEventArgs e)
    {
        Content = e.Value?.ToString() ?? string.Empty;

        await ContentChanged.InvokeAsync(Content);
    }

    private async Task HandleTitleInput(ChangeEventArgs e)
    {
        Title = e.Value?.ToString() ?? string.Empty;
        await TitleChanged.InvokeAsync(Title);
    }

    private async Task InsertEntryAsync(string Content, string Title)
    {
        await JS.InvokeVoidAsync("TextEditor.setContent", _editorDiv, Content);
        await JS.InvokeVoidAsync("TextEditor.setContent", _titleInput, Title);
    }
}